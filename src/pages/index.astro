---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Aprende Español">
  <section class="hero">
    <p class="hero-eyebrow">Español para germanohablantes</p>
    <h1>Milhojas</h1>
    <p class="hero-sub">Aprende español capa por capa. Vocabulario, conjugaciones y mas.</p>
  </section>

  <div class="container">
    <div class="mode-cards">
      <a href="/vocabulario" class="card mode-card">
        <div class="mode-icon-wrap mode-icon-red">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            <line x1="8" y1="7" x2="16" y2="7"/>
            <line x1="8" y1="11" x2="14" y2="11"/>
          </svg>
        </div>
        <h3>Vocabulario</h3>
        <p>200+ Wörter in 12 Kategorien. Multiple Choice mit Speed- und Streak-Bonus.</p>
        <span class="mode-cta">Quiz starten</span>
      </a>
      <a href="/conjugacion" class="card mode-card">
        <div class="mode-icon-wrap mode-icon-blue">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 20h9"/>
            <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
          </svg>
        </div>
        <h3>Conjugacion</h3>
        <p>35 Verben in 3 Zeitformen. Tippe die richtige konjugierte Form ein.</p>
        <span class="mode-cta">Quiz starten</span>
      </a>
    </div>
  </div>

  <div class="stats-bar">
    <div class="container">
      <div class="stats-inner">
        <div class="stat-item">
          <span class="stat-num">200+</span>
          <span class="stat-desc">Wörter</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">35</span>
          <span class="stat-desc">Verben</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">3</span>
          <span class="stat-desc">Zeitformen</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">12</span>
          <span class="stat-desc">Kategorien</span>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .mode-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .mode-icon-red {
    background: rgba(213, 43, 30, 0.08);
    color: var(--chile-red);
  }
  .mode-icon-blue {
    background: rgba(0, 57, 166, 0.06);
    color: var(--chile-blue);
  }
  .mode-cta {
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    margin-top: auto;
    padding-top: var(--space-sm);
    transition: color 0.2s ease;
  }
  .mode-card:hover .mode-cta {
    color: var(--text);
  }
  .stats-bar {
    margin-top: var(--space-2xl);
    padding: var(--space-xl) 0;
    border-top: 1px solid var(--border);
  }
  .stats-inner {
    display: flex;
    justify-content: center;
    gap: var(--space-2xl);
  }
  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .stat-num {
    font-family: var(--mono);
    font-size: 24px;
    font-weight: 700;
    color: var(--text);
  }
  .stat-desc {
    font-family: var(--mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
  }
  @media (max-width: 480px) {
    .stats-inner { gap: var(--space-lg); }
    .stat-num { font-size: 20px; }
  }
</style>
