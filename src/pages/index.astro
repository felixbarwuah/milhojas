---
import BaseLayout from '../layouts/BaseLayout.astro';
import Dashboard from '../components/Dashboard';
---

<BaseLayout title="Spanisch lernen">
  <section class="hero">
    <p class="hero-eyebrow">Spanisch lernen mit Felix</p>
    <h1>Milhojas</h1>
    <p class="hero-sub">Nutze diese Spanisch Lernapp um dein Spanisch auf die nächste Ebene zu bringen und dich bald fließend mit Locals zu unterhalten.</p>
  </section>

  <div class="container">
    <Dashboard client:load />

    <div class="mode-cards four-cols">
      <a href="/karteikarten" class="card mode-card">
        <div class="mode-icon-wrap mode-icon-green">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="M2 8h20"/>
          </svg>
        </div>
        <h2 class="mode-card-title">Karteikarten</h2>
        <p>Spaced Repetition. Was du nicht kannst, kommt öfter.</p>
        <span class="mode-cta">Lernen</span>
      </a>
      <a href="/schreiben" class="card mode-card">
        <div class="mode-icon-wrap mode-icon-amber">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 20h9"/>
            <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
          </svg>
        </div>
        <h2 class="mode-card-title">Schreiben</h2>
        <p>Übersetzung selbst tippen. Schwerer, aber effektiver.</p>
        <span class="mode-cta">Üben</span>
      </a>
      <a href="/vocabulario" class="card mode-card">
        <div class="mode-icon-wrap mode-icon-red">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            <line x1="8" y1="7" x2="16" y2="7"/>
            <line x1="8" y1="11" x2="14" y2="11"/>
          </svg>
        </div>
        <h2 class="mode-card-title">Vokabel-Quiz</h2>
        <p>Multiple Choice. 200+ Wörter in 12 Kategorien.</p>
        <span class="mode-cta">Quiz</span>
      </a>
      <a href="/conjugacion" class="card mode-card">
        <div class="mode-icon-wrap mode-icon-blue">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="17" y1="10" x2="3" y2="10"/>
            <line x1="21" y1="6" x2="3" y2="6"/>
            <line x1="21" y1="14" x2="3" y2="14"/>
            <line x1="17" y1="18" x2="3" y2="18"/>
          </svg>
        </div>
        <h2 class="mode-card-title">Konjugation</h2>
        <p>35 Verben in 3 Zeitformen konjugieren.</p>
        <span class="mode-cta">Quiz</span>
      </a>
      <a href="/lesen" class="card mode-card">
        <div class="mode-icon-wrap mode-icon-teal">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
        </div>
        <h2 class="mode-card-title">Lesen</h2>
        <p>Spanische Texte lesen und Fragen beantworten.</p>
        <span class="mode-cta">Lesen</span>
      </a>
      <a href="/grammatik" class="card mode-card">
        <div class="mode-icon-wrap mode-icon-indigo">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
        </div>
        <h2 class="mode-card-title">Grammatik</h2>
        <p>A1/A2 Regeln verstehen und mit Übungen festigen.</p>
        <span class="mode-cta">Lernen</span>
      </a>
      <a href="/fakten" class="card mode-card">
        <div class="mode-icon-wrap mode-icon-orange">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
          </svg>
        </div>
        <h2 class="mode-card-title">Fakten</h2>
        <p>Spannendes über Chile, Spanien und die Sprache.</p>
        <span class="mode-cta">Quiz</span>
      </a>
      <a href="/texte" class="card mode-card">
        <div class="mode-icon-wrap mode-icon-purple">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 7V4h16v3"/><path d="M9 20h6"/><path d="M12 4v16"/>
          </svg>
        </div>
        <h2 class="mode-card-title">Lückentext</h2>
        <p>Finde das fehlende Wort im spanischen Satz.</p>
        <span class="mode-cta">Üben</span>
      </a>
    </div>
  </div>

  <div class="stats-bar">
    <div class="container">
      <div class="stats-inner">
        <div class="stat-item">
          <span class="stat-num">615</span>
          <span class="stat-desc">Wörter</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">35</span>
          <span class="stat-desc">Verben</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">8</span>
          <span class="stat-desc">Lernmodi</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">16</span>
          <span class="stat-desc">Kategorien</span>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .mode-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .mode-icon-red { background: rgba(213, 43, 30, 0.08); color: var(--chile-red); }
  .mode-icon-blue { background: rgba(0, 57, 166, 0.06); color: var(--chile-blue); }
  .mode-icon-green { background: rgba(22, 163, 74, 0.08); color: #16A34A; }
  .mode-icon-amber { background: rgba(217, 119, 6, 0.08); color: #D97706; }
  .mode-icon-purple { background: rgba(139, 92, 246, 0.08); color: #8B5CF6; }
  .mode-icon-teal { background: rgba(20, 184, 166, 0.08); color: #14B8A6; }
  .mode-icon-indigo { background: rgba(99, 102, 241, 0.08); color: #6366F1; }
  .mode-icon-orange { background: rgba(249, 115, 22, 0.08); color: #F97316; }
  .mode-cta {
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    margin-top: auto;
    padding-top: var(--space-sm);
    transition: color 0.2s ease;
  }
  .mode-card:hover .mode-cta { color: var(--text); }
  .stats-bar {
    margin-top: var(--space-2xl);
    padding: var(--space-xl) 0;
    border-top: 1px solid var(--border);
  }
  .stats-inner { display: flex; justify-content: center; gap: var(--space-2xl); }
  .stat-item { display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .stat-num { font-family: var(--mono); font-size: 24px; font-weight: 700; color: var(--text); }
  .stat-desc { font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted); }
  @media (max-width: 480px) {
    .stats-inner { gap: var(--space-lg); }
    .stat-num { font-size: 20px; }
  }
</style>
