---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LoginForm from '../../components/LoginForm';
---

<BaseLayout title="Registrieren">
  <div class="login-page">
    <h1 class="login-title">Jetzt kostenlos registrieren</h1>
    <p class="login-sub">Speichere deinen Lernfortschritt und lerne auf allen Geräten.</p>

    <LoginForm client:load />

    <p class="login-switch">Du hast schon einen Account? <a href="/auth/login">Zum Login</a></p>
  </div>
</BaseLayout>

<style>
  .login-page {
    max-width: 440px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-lg) var(--space-2xl);
  }
  .login-title {
    font-size: 28px;
    font-weight: 800;
    text-align: center;
    margin-bottom: var(--space-sm);
    font-style: italic;
  }
  .login-sub {
    text-align: center;
    font-size: 15px;
    color: var(--text-secondary);
    margin-bottom: var(--space-xl);
  }
  .login-switch {
    text-align: center;
    font-size: 14px;
    color: var(--text-muted);
    margin-top: var(--space-xl);
  }
  .login-switch a {
    color: var(--accent);
    font-weight: 600;
  }
</style>
