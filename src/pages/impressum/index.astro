<style>
  .legal { max-width: 600px; padding-top: var(--space-xl); padding-bottom: var(--space-2xl); }
  .legal h1 { font-size: 28px; margin-bottom: var(--space-lg); }
  .legal h2 { font-size: 18px; margin-top: var(--space-lg); margin-bottom: var(--space-sm); }
  .legal p { font-size: 15px; color: var(--text-secondary); line-height: 1.7; }
</style>
