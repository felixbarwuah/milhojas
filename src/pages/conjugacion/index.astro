---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ConjugationQuiz from '../../components/ConjugationQuiz';
---

<BaseLayout title="Conjugacion" description="Spanische Verben konjugieren - Quiz">
  <section class="hero" style="padding-bottom: var(--space-md);">
    <p class="hero-eyebrow">Conjugacion</p>
    <h2>Konjugations-Quiz</h2>
    <p class="hero-sub" style="font-size: 16px;">Wähle Zeitform und Schwierigkeit, dann tippe die richtige Form.</p>
  </section>

  <ConjugationQuiz client:load />
</BaseLayout>
