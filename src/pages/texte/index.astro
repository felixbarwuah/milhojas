---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SentenceMiner from '../../components/SentenceMiner';
---

<BaseLayout title="Texte entdecken" description="Spanische Texte analysieren und neue Wörter lernen">
  <section class="hero" style="padding-bottom: var(--space-md);">
    <p class="hero-eyebrow">Textanalyse</p>
    <h2>Texte entdecken</h2>
    <p class="hero-sub" style="font-size: 16px;">Spanischen Text einfügen, unbekannte Wörter anklicken und zum Lernen hinzufügen.</p>
  </section>

  <SentenceMiner client:load />
</BaseLayout>
