---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Spanisch lernen - Vokabeln und Konjugationen' } = Astro.props;
const path = Astro.url.pathname;
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#D52B1E" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <title>{title} | Milhojas</title>
    <link rel="stylesheet" href="/fonts/fonts.css" />
    <link rel="stylesheet" href="/styles/global.css" />
    <link rel="stylesheet" href="/styles/quiz.css" />
  </head>
  <body>
    <div class="chile-stripe"></div>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo">
          <img src="/icons/logo-chili.png" alt="" width="24" height="24" class="logo-img" />
          <span class="logo-text">MILHOJAS</span>
        </a>
        {path !== '/' && (
          <div class="nav-buttons">
            <a href="#" class="nav-btn" id="back-btn" aria-label="Zurück">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            </a>
            <a href="/" class="nav-btn" aria-label="Startseite">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </a>
          </div>
        )}
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <img src="/icons/logo-chili.png" alt="" width="20" height="20" />
          <span class="footer-logo">MILHOJAS</span>
        </div>
        <p class="footer-tagline">Spanisch lernen mit Felix</p>
      </div>
    </footer>
    <script>
      document.getElementById('back-btn')?.addEventListener('click', (e) => {
        e.preventDefault();
        history.back();
      });
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').then((reg) => {
          // Check for updates every 60 seconds
          setInterval(() => reg.update(), 60000);
          // When new SW is waiting, activate it immediately
          reg.addEventListener('updatefound', () => {
            const newSW = reg.installing;
            if (newSW) {
              newSW.addEventListener('statechange', () => {
                if (newSW.state === 'activated') {
                  window.location.reload();
                }
              });
            }
          });
        }).catch(() => {});
      }
    </script>
  </body>
</html>

<style>
  .site-header {
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--border);
    background: var(--bg-card);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 800px;
    min-height: 40px;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text);
  }
  .logo:hover {
    color: var(--text);
  }
  .logo-img {
    flex-shrink: 0;
    border-radius: 4px;
  }
  .logo-text {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text);
  }
  .nav-buttons {
    display: flex;
    gap: 8px;
  }
  .nav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--border-strong);
    border-radius: 50%;
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .nav-btn:hover {
    color: var(--text);
    border-color: var(--text-secondary);
    background: rgba(0, 0, 0, 0.03);
  }
  .site-footer {
    margin-top: var(--space-2xl);
    padding: var(--space-xl) 0;
    border-top: 1px solid var(--border);
  }
  .footer-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .footer-logo {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .footer-tagline {
    font-family: var(--sans);
    font-size: 13px;
    color: var(--text-label);
  }
  @media (max-width: 480px) {
    .logo-text { font-size: 11px; }
  }
</style>
